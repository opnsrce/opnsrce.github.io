                "url": "/blog/"
            },
            {
                "identifier": "docs",
                "name": "Docs",
                "url": "/docs/"
            },
            {
                "identifier": "links",
                "name": "Links",
                "url": "/links/"
            },
            {
                "identifier": "projects",
                "name": "Projects",
                "url": "/projects/"
            },
            {
                "identifier": "about",
                "name": "About",
                "url": "/about/"
            }
        ]
    },
    "markup": {
        "goldmark": {
            "extensions": {
                "typographer": true
            }
        }
    },
    "taxonomies": {
        "tag": "tags",
        "tech": "tech",
        "series": "series"
